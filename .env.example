# Example environment template
# SECURITY: Never commit real secrets or production credentials to git.

# API Configuration (Connect to Backend)
NEXT_PUBLIC_API_URL="http://localhost:6859/api"
# Optional FE-side upload size hint (bytes). 209715200 = 200MB
NEXT_PUBLIC_MAX_UPLOAD_SIZE_BYTES="209715200"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://<SUPABASE_PROJECT_REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="<SUPABASE_PUBLISHABLE_KEY>"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<SUPABASE_ANON_KEY>"

# NextAuth.js
# Use your machine LAN IP when accessing from devices in the same network, e.g. http://192.168.1.50:6849
NEXTAUTH_URL="http://localhost:6849"
NEXTAUTH_SECRET="<NEXTAUTH_SECRET>"

# OAuth Providers
GOOGLE_CLIENT_ID="<GOOGLE_CLIENT_ID>"
GOOGLE_CLIENT_SECRET="<GOOGLE_CLIENT_SECRET>"
AZURE_AD_CLIENT_ID="<AZURE_AD_CLIENT_ID>"
AZURE_AD_CLIENT_SECRET="<AZURE_AD_CLIENT_SECRET>"
AZURE_AD_TENANT_ID="<AZURE_AD_TENANT_ID>"
AZURE_AD_REDIRECT_URI="http://localhost:6849/api/auth/callback/azure-ad"

# Microsoft Entra ID / Azure AD Configuration
NEXT_PUBLIC_MSAL_CLIENT_ID="<AZURE_AD_CLIENT_ID>"
NEXT_PUBLIC_MSAL_TENANT_ID="<AZURE_AD_TENANT_ID>"
# For MSAL.js, point Redirect URI to your frontend callback/login route
NEXT_PUBLIC_REDIRECT_URI="http://localhost:6849/api/auth/callback/azure-ad"

# Backend Exchange Secrets (server-only)
MSAL_CLIENT_SECRET="<AZURE_AD_CLIENT_SECRET>"

# Note:
# - DATABASE_URL, MINIO_*, AZURE_* are NO LONGER NEEDED here.
# - They have been moved to BackEnd/.env
